@model IEnumerable<EduManage.Models.StudyMaterial>
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Study Materials";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var role = Context.Session.GetString("Role");
    var teacherMap = (Dictionary<int, string>)ViewBag.Teachers;

    // Admin/Teacher filters
    var classes = (List<string>)ViewBag.Classes;
    var selectedClass = (string)ViewBag.SelectedClass;
}

<div class="dashboard">
    @if (role == "Admin") { @await Html.PartialAsync("_AdminSidebar") }
    else if (role == "Teacher") { @await Html.PartialAsync("_TeacherSidebar") }
    else if (role == "Student") { @await Html.PartialAsync("_StudentSidebar") }

    <main class="main-content">
        <div class="page-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:15px;">
            <div>
                <div class="page-title">Study Materials</div>
                <div class="page-sub">Access and download lecture notes, PDFs, and learning resources.</div>
            </div>
            @if (role == "Teacher" || role == "Admin")
            {
                <div>
                    <a href="/StudyMaterial/Upload" class="btn btn-primary">+ Upload Study Material</a>
                </div>
            }
        </div>

        @if (role == "Admin" || role == "Teacher")
        {
            <div class="card" style="margin-bottom:20px;">
                <div class="card-title">Filter Resources</div>
                <form method="get" action="/StudyMaterial/Index" style="display:flex; gap:15px; align-items:flex-end; flex-wrap:wrap;">
                    <div style="flex:1; min-width:200px;">
                        <label class="field-label">Filter by Class</label>
                        <select class="field-select" name="classFilter">
                            <option value="">All Classes</option>
                            @foreach (var c in classes)
                            {
                                <!option value="@c" @(c == selectedClass ? "selected" : "")>@c</!option>
                            }
                        </select>
                    </div>
                    <div>
                        <button type="submit" class="btn btn-primary" style="margin-bottom:0;">Filter</button>
                    </div>
                </form>
            </div>
        }

        <div class="card">
            <div class="card-title">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.168.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.168.477-4.5 1.253"/>
                </svg>
                Resources Repository
            </div>

            @if (Model != null && Model.Any())
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Resource Title</th>
                            <th>Class</th>
                            <th>Uploaded By</th>
                            <th>Date Uploaded</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var material in Model)
                        {
                            var author = "System";
                            if (material.TeacherId != 0 && teacherMap.ContainsKey(material.TeacherId))
                            {
                                author = teacherMap[material.TeacherId];
                            }
                            else if (material.TeacherId == 0)
                            {
                                author = "Administrator";
                            }
                            <tr>
                                <td>
                                    <strong>@material.Title</strong>
                                    @if (!string.IsNullOrEmpty(material.Description))
                                    {
                                        <div style="font-size:12px; color:var(--gray-500); margin-top:3px;">@material.Description</div>
                                    }
                                </td>
                                <td>@material.Class</td>
                                <td>@author</td>
                                <td>@material.UploadedAt.ToString("dd MMM yyyy")</td>
                                <td>
                                    <div style="display:flex; gap:10px;">
                                        <a href="@material.FilePath" target="_blank" class="btn btn-outline" style="font-size:12px; padding:6px 12px; display:inline-flex; align-items:center; gap:5px;">
                                            <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                                <path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                                            </svg>
                                            Download
                                        </a>
                                        
                                        @if (role == "Admin" || (role == "Teacher" && material.TeacherId == (Context.Session.GetInt32("TeacherId") ?? 0)))
                                        {
                                            <form method="post" action="/StudyMaterial/Delete" onsubmit="return confirm('Are you sure you want to delete this resource?');" style="margin:0;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@material.Id" />
                                                <button type="submit" class="btn btn-danger" style="font-size:12px; padding:6px 12px; margin-bottom:0;">Delete</button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div style="color:var(--gray-400); padding:30px; text-align:center;">No study materials available.</div>
            }
        </div>
    </main>
</div>
