@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Compose Message";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var role = Context.Session.GetString("Role");
    var recipients = ViewBag.Recipients;
}

<div class="dashboard">
    @if (role == "Teacher") { @await Html.PartialAsync("_TeacherSidebar") }
    else if (role == "Student") { @await Html.PartialAsync("_StudentSidebar") }

    <main class="main-content">
        <div class="page-header">
            <div class="page-title">Compose Message</div>
            <div class="page-sub">Send an internal message.</div>
        </div>

        <div class="card">
            <div class="card-title">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
                Message Details
            </div>

            <form method="post" action="/Message/Send">
                @Html.AntiForgeryToken()

                <div class="form-row">
                    <div>
                        <label class="field-label">Recipient *</label>
                        <select class="field-select" name="receiverId" required>
                            <option value="">Select Recipient</option>
                            @if (recipients != null)
                            {
                                @foreach (var r in recipients)
                                {
                                    // Using dynamic type or casting properties
                                    var idProp = r.GetType().GetProperty("Id")?.GetValue(r, null);
                                    var nameProp = r.GetType().GetProperty("Name")?.GetValue(r, null);
                                    <option value="@idProp">@nameProp</option>
                                }
                            }
                        </select>
                    </div>
                    <div>
                        <label class="field-label">Subject *</label>
                        <input class="field-input" type="text" name="subject" placeholder="Enter message subject" required />
                    </div>
                </div>

                <div class="form-row full">
                    <div>
                        <label class="field-label">Message Body *</label>
                        <textarea class="field-input" name="body" placeholder="Type your message here..." rows="6" required style="height:auto; font-family:inherit; padding:10px;"></textarea>
                    </div>
                </div>

                <div class="form-actions">
                    <a href="/Message/Inbox" class="btn btn-outline">Cancel</a>
                    <button type="submit" class="btn btn-primary">Send Message</button>
                </div>
            </form>
        </div>
    </main>
</div>
