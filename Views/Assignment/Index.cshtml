@model IEnumerable<EduManage.Models.Assignment>
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Assignments";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var role = Context.Session.GetString("Role");
    var submissions = (Dictionary<int, string>)ViewBag.Submissions;
}

<div class="dashboard">
    @if (role == "Admin") { @await Html.PartialAsync("_AdminSidebar") }
    else if (role == "Teacher") { @await Html.PartialAsync("_TeacherSidebar") }
    else if (role == "Student") { @await Html.PartialAsync("_StudentSidebar") }

    <main class="main-content">
        <div class="page-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:15px;">
            <div>
                <div class="page-title">Assignments</div>
                <div class="page-sub">Manage, upload, and track classroom assignments.</div>
            </div>
            @if (role == "Teacher")
            {
                <div>
                    <a href="/Assignment/Create" class="btn btn-primary">+ Create New Assignment</a>
                </div>
            }
        </div>

        <div class="card">
            <div class="card-title">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
                Current Assignments
            </div>

            @if (Model != null && Model.Any())
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Class</th>
                            <th>Due Date</th>
                            @if (role == "Student")
                            {
                                <th>Status</th>
                            }
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var assignment in Model)
                        {
                            <tr>
                                <td><strong>@assignment.Title</strong></td>
                                <td>@assignment.Class</td>
                                <td>
                                    <span style="color:@(assignment.DueDate < DateTime.Now ? "var(--red)" : "inherit");">
                                        @assignment.DueDate.ToString("dd MMM yyyy, hh:mm tt")
                                    </span>
                                </td>
                                @if (role == "Student")
                                {
                                    <td>
                                        @{
                                            var status = "Not Submitted";
                                            if (submissions != null && submissions.ContainsKey(assignment.Id))
                                            {
                                                status = submissions[assignment.Id];
                                            }
                                        }
                                        @if (status == "Not Submitted")
                                        {
                                            <span class="badge badge-gray">Not Submitted</span>
                                        }
                                        else if (status == "Submitted")
                                        {
                                            <span class="badge badge-blue">Submitted</span>
                                        }
                                        else if (status == "Graded")
                                        {
                                            <span class="badge badge-green">Graded</span>
                                        }
                                    </td>
                                }
                                <td>
                                    <a href="/Assignment/Details/@assignment.Id" class="btn btn-outline" style="font-size:12px; padding:6px 12px;">
                                        @(role == "Student" ? "View & Submit" : "View Submissions")
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div style="color:var(--gray-400); padding:30px; text-align:center;">No assignments found.</div>
            }
        </div>
    </main>
</div>
