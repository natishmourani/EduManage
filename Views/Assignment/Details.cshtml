@model EduManage.Models.Assignment
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Assignment Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var role = Context.Session.GetString("Role");
    var teacherName = (string)ViewBag.TeacherName;

    // Student specific variables
    var submission = (EduManage.Models.AssignmentSubmission)ViewBag.Submission;

    // Teacher/Admin specific variables
    var classStudents = (List<EduManage.Models.Student>)ViewBag.ClassStudents;
    var submissionMap = (Dictionary<int, EduManage.Models.AssignmentSubmission>)ViewBag.SubmissionMap;
}

<div class="dashboard">
    @if (role == "Admin") { @await Html.PartialAsync("_AdminSidebar") }
    else if (role == "Teacher") { @await Html.PartialAsync("_TeacherSidebar") }
    else if (role == "Student") { @await Html.PartialAsync("_StudentSidebar") }

    <main class="main-content">
        <div class="page-header" style="display:flex; justify-content:space-between; align-items:center;">
            <div>
                <div class="page-title">Assignment Details</div>
                <div class="page-sub">Published by @teacherName for @Model.Class</div>
            </div>
            <div>
                <a href="/Assignment/Index" class="btn btn-outline">&larr; Back to list</a>
            </div>
        </div>

        <div class="card">
            <div style="display:flex; justify-content:space-between; border-bottom:1px solid var(--gray-200); padding-bottom:15px; margin-bottom:15px; flex-wrap:wrap; gap:10px;">
                <div>
                    <h2 style="margin:0 0 5px 0;">@Model.Title</h2>
                    <span style="font-size:12px; color:var(--gray-400);">Published on @Model.CreatedAt.ToString("g")</span>
                </div>
                <div style="text-align:right;">
                    <div style="font-size:13px; font-weight:700; color:var(--gray-700);">Due Date:</div>
                    <span class="badge @(Model.DueDate < DateTime.Now ? "badge-danger" : "badge-blue")">
                        @Model.DueDate.ToString("g")
                    </span>
                </div>
            </div>

            <div style="margin-bottom:20px;">
                <h4 style="margin-bottom:8px;">Description / Instructions:</h4>
                <p style="white-space:pre-wrap; line-height:1.6; color:var(--gray-700); font-size:14px; background:var(--gray-50); padding:15px; border-radius:8px;">@Model.Description</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.FilePath))
            {
                <div style="margin-bottom:10px;">
                    <strong>Attachment:</strong> &nbsp;
                    <a href="@Model.FilePath" target="_blank" class="btn btn-outline" style="font-size:12px; padding:6px 12px; display:inline-flex; align-items:center; gap:5px;">
                        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                        </svg>
                        Download Reference File
                    </a>
                </div>
            }
        </div>

        <!-- Role specific content -->
        @if (role == "Student")
        {
            <div class="card" style="margin-top:20px;">
                <div class="card-title">
                    My Submission
                </div>

                @if (submission == null)
                {
                    if (Model.DueDate < DateTime.Now)
                    {
                        <p style="color:var(--red); font-weight:700;">The due date has passed. You cannot submit this assignment.</p>
                    }
                    else
                    {
                        <form method="post" action="/Assignment/Submit" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="assignmentId" value="@Model.Id" />
                            
                            <div class="form-row">
                                <div>
                                    <label class="field-label">Upload Submission File *</label>
                                    <input class="field-input" type="file" name="file" required />
                                    <span style="font-size:12px; color:var(--gray-400);">PDF, Word, Images, or Zip files are accepted.</span>
                                </div>
                            </div>
                            
                            <div class="form-actions" style="margin-top:15px;">
                                <button type="submit" class="btn btn-primary">Submit Assignment</button>
                            </div>
                        </form>
                    }
                }
                else
                {
                    <div style="display:flex; justify-content:space-between; flex-wrap:wrap; gap:15px; border-bottom:1px solid var(--gray-100); padding-bottom:15px; margin-bottom:15px;">
                        <div>
                            <span class="badge @(submission.Status == "Graded" ? "badge-green" : "badge-blue")" style="margin-bottom:10px;">
                                @submission.Status
                            </span>
                            <div>
                                <strong>Submitted file:</strong> &nbsp;
                                <a href="@submission.FilePath" target="_blank" style="color:var(--primary); text-decoration:underline;">Download My Submission</a>
                            </div>
                            <div style="font-size:12px; color:var(--gray-400); margin-top:5px;">Submitted on @submission.SubmissionDate.ToString("g")</div>
                        </div>

                        @if (submission.Status == "Graded")
                        {
                            <div style="background:var(--gray-50); padding:10px 15px; border-radius:8px; min-width:200px;">
                                <div style="font-weight:700; color:var(--gray-800);">Grade: <span style="color:var(--green); font-size:18px;">@submission.Grade</span></div>
                                <div style="font-size:13px; color:var(--gray-600); margin-top:5px;"><strong>Feedback:</strong> @submission.Feedback</div>
                            </div>
                        }
                    </div>

                    @if (submission.Status != "Graded" && Model.DueDate >= DateTime.Now)
                    {
                        <!-- Allow resubmission -->
                        <h4 style="margin:20px 0 10px 0;">Resubmit Assignment</h4>
                        <form method="post" action="/Assignment/Submit" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="assignmentId" value="@Model.Id" />
                            
                            <div class="form-row">
                                <div>
                                    <label class="field-label">Upload New File</label>
                                    <input class="field-input" type="file" name="file" required />
                                </div>
                            </div>
                            
                            <div class="form-actions" style="margin-top:10px;">
                                <button type="submit" class="btn btn-primary">Update Submission</button>
                            </div>
                        </form>
                    }
                }
            </div>
        }
        else if (role == "Teacher" || role == "Admin")
        {
            <div class="card" style="margin-top:20px;">
                <div class="card-title">
                    Student Submissions
                </div>

                @if (classStudents != null && classStudents.Any())
                {
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Roll No</th>
                                <th>Student Name</th>
                                <th>Status</th>
                                <th>File</th>
                                <th>Grade / Feedback</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in classStudents)
                            {
                                var submitted = submissionMap.ContainsKey(s.Id);
                                var sub = submitted ? submissionMap[s.Id] : null;

                                <tr>
                                    <td>@s.RollNumber</td>
                                    <td>@s.FullName</td>
                                    <td>
                                        @if (!submitted)
                                        {
                                            <span class="badge badge-danger">Pending</span>
                                        }
                                        else
                                        {
                                            <span class="badge @(sub.Status == "Graded" ? "badge-green" : "badge-blue")">@sub.Status</span>
                                        }
                                    </td>
                                    <td>
                                        @if (submitted)
                                        {
                                            <a href="@sub.FilePath" target="_blank" class="btn btn-outline" style="font-size:11px; padding:4px 8px;">Download File</a>
                                        }
                                        else
                                        {
                                            <span>—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (submitted)
                                        {
                                            if (sub.Status == "Graded")
                                            {
                                                <div>
                                                    <strong>Grade:</strong> <span style="color:var(--green); font-weight:700;">@sub.Grade</span><br />
                                                    <span style="font-size:12px; color:var(--gray-500);">@sub.Feedback</span>
                                                </div>
                                            }

                                            if (role == "Teacher")
                                            {
                                                <button onclick="toggleGradeForm(@sub.Id)" class="btn btn-outline" style="font-size:11px; padding:4px 8px; margin-top:5px;">
                                                    @(sub.Status == "Graded" ? "Change Grade" : "Enter Grade")
                                                </button>

                                                <form id="gradeForm-@sub.Id" method="post" action="/Assignment/Grade" style="display:none; margin-top:10px; background:var(--gray-50); padding:10px; border-radius:6px; border:1px solid var(--gray-200);">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="submissionId" value="@sub.Id" />
                                                    <div style="margin-bottom:8px;">
                                                        <label class="field-label" style="font-size:11px; margin-bottom:2px;">Grade (e.g. A+, B, 85/100) *</label>
                                                        <input class="field-input" type="text" name="grade" value="@sub.Grade" required style="padding:6px 10px; font-size:12px;" />
                                                    </div>
                                                    <div style="margin-bottom:8px;">
                                                        <label class="field-label" style="font-size:11px; margin-bottom:2px;">Feedback</label>
                                                        <input class="field-input" type="text" name="feedback" value="@sub.Feedback" style="padding:6px 10px; font-size:12px;" />
                                                    </div>
                                                    <div style="display:flex; gap:5px;">
                                                        <button type="submit" class="btn btn-primary" style="font-size:11px; padding:4px 8px; margin-bottom:0;">Save</button>
                                                        <button type="button" onclick="toggleGradeForm(@sub.Id)" class="btn btn-outline" style="font-size:11px; padding:4px 8px; margin-bottom:0;">Cancel</button>
                                                    </div>
                                                </form>
                                            }
                                        }
                                        else
                                        {
                                            <span>—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div style="color:var(--gray-400); padding:20px; text-align:center;">No students registered in this class.</div>
                }
            </div>
        }
    </main>
</div>

<script>
    function toggleGradeForm(id) {
        var form = document.getElementById('gradeForm-' + id);
        if (form.style.display === 'none' || form.style.display === '') {
            form.style.display = 'block';
        } else {
            form.style.display = 'none';
        }
    }
</script>
