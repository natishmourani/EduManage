@model EduManage.Models.Student
@{
    ViewData["Title"] = "Change Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="dashboard">
    @await Html.PartialAsync("_AdminSidebar")

    <main class="main-content">
        <div class="page-header">
            <div class="page-title">Change details</div>
            <div class="page-sub">Update student information.</div>
        </div>

        <!-- Search to load a student -->
        <div class="card" style="margin-bottom:16px;">
            <div class="card-title">Search Student</div>
            <form asp-action="ChangeDetails" asp-controller="Admin" method="get">
                <div style="display:flex;gap:10px;">
                    <input class="field-input" name="rollNo" placeholder="Enter roll number..." value="@ViewBag.RollNo" style="flex:1;" />
                    <button type="submit" class="btn btn-primary">Search</button>
                </div>
            </form>
        </div>

        @if (Model != null)
        {
            <div class="card">
                <div class="card-title">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                    Edit student — @Model.FullName
                </div>

                <form asp-action="UpdateStudent" asp-controller="Admin" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@Model.Id" />

                    <div class="form-row">
                        <div>
                            <label class="field-label">Full name *</label>
                            <input class="field-input" name="FullName" value="@Model.FullName" required />
                        </div>
                        <div>
                            <label class="field-label">Father's name *</label>
                            <input class="field-input" name="FatherName" value="@Model.FatherName" required />
                        </div>
                    </div>

                    <div class="form-row">
                        <div>
                            <label class="field-label">Date of birth</label>
                            <input class="field-input" type="date" name="DateOfBirth"
                                   value="@Model.DateOfBirth?.ToString("yyyy-MM-dd")" max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </div>
                        <div>
                            <label class="field-label">Gender *</label>
                            <select asp-for="Gender" class="field-select">
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                             </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div>
                            <label class="field-label">Class *</label>
                            <input class="field-input" name="Class" value="@Model.Class" required />
                        </div>
                        <div>
                            <label class="field-label">Section</label>
                            <select asp-for="Section" class="field-select">
                              <option value="A">A</option>
                              <option value="B">B</option>
                              <option value="C">C</option>
                              <option value="D">D</option>
                             </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div>
                            <label class="field-label">Contact number</label>
                            <input class="field-input" name="Contact" value="@Model.Contact" />
                        </div>
                        <div>
                            <label class="field-label">Roll number</label>
                            <input class="field-input" value="@Model.RollNumber" readonly />
                        </div>
                    </div>

                    <div class="form-row">
                        <div>
                            <label class="field-label">Password *</label>
                            <input class="field-input" name="Password" value="@Model.Password" required />
                        </div>
                        <div></div>
                    </div>

                    <div class="form-row full">
                        <div>
                            <label class="field-label">Home address</label>
                            <input class="field-input" name="Address" value="@Model.Address" />
                        </div>
                    </div>

                    @if (ViewBag.Success != null)
                    {
                        <p style="color: var(--green); font-size:13px; margin-bottom:10px;">@ViewBag.Success</p>
                    }

                    <div class="form-actions">
                        <button type="reset" class="btn btn-outline">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save changes</button>
                    </div>
                </form>
            </div>
        }
        else if (ViewBag.NotFound == true)
        {
            <div class="card" style="text-align:center;padding:40px;color:var(--gray-400);">
                Student not found. Please check the roll number.
            </div>
        }
    </main>
</div>
