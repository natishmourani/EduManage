@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var stats = (EduManage.Models.DashboardStats)ViewBag.Stats;
    var recentAnnouncements = (List<EduManage.Models.Announcement>)ViewBag.RecentAnnouncements;
    var upcomingEvents = (List<EduManage.Models.Event>)ViewBag.UpcomingEvents;
}

<div class="dashboard">
    @await Html.PartialAsync("_AdminSidebar")

    <main class="main-content">
        <div class="page-header">
            <div class="page-title">Admin Dashboard</div>
            <div class="page-sub">Welcome to the administration control panel. Here is the school's overview.</div>
        </div>

        <!-- Metric Grid -->
        <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap:20px; margin-bottom:25px;">
            <div class="card" style="border-left: 5px solid var(--purple); padding:20px; display:flex; flex-direction:column; justify-content:center;">
                <div style="font-size:12px; font-weight:700; color:var(--gray-400); text-transform:uppercase;">Total Students</div>
                <div style="font-size:32px; font-weight:800; color:var(--gray-800); margin:5px 0;">@stats.TotalStudents</div>
                <a href="/Admin/AddStudent" style="font-size:12px; color:var(--purple); font-weight:700;">Manage Students &rarr;</a>
            </div>
            <div class="card" style="border-left: 5px solid var(--green); padding:20px; display:flex; flex-direction:column; justify-content:center;">
                <div style="font-size:12px; font-weight:700; color:var(--gray-400); text-transform:uppercase;">Total Teachers</div>
                <div style="font-size:32px; font-weight:800; color:var(--gray-800); margin:5px 0;">@stats.TotalTeachers</div>
                <a href="/Admin/AddTeacher" style="font-size:12px; color:var(--green); font-weight:700;">Manage Teachers &rarr;</a>
            </div>
            <div class="card" style="border-left: 5px solid var(--amber); padding:20px; display:flex; flex-direction:column; justify-content:center;">
                <div style="font-size:12px; font-weight:700; color:var(--gray-400); text-transform:uppercase;">Pending Leaves</div>
                <div style="font-size:32px; font-weight:800; color:var(--gray-800); margin:5px 0;">@stats.PendingLeaves</div>
                <a href="/Leave/Index" style="font-size:12px; color:var(--amber); font-weight:700;">Review Leaves &rarr;</a>
            </div>
            <div class="card" style="border-left: 5px solid var(--primary); padding:20px; display:flex; flex-direction:column; justify-content:center;">
                <div style="font-size:12px; font-weight:700; color:var(--gray-400); text-transform:uppercase;">Active Events</div>
                <div style="font-size:32px; font-weight:800; color:var(--gray-800); margin:5px 0;">@stats.TotalEvents</div>
                <a href="/Event/Index" style="font-size:12px; color:var(--primary); font-weight:700;">View Calendar &rarr;</a>
            </div>
        </div>

        <div style="display:grid; grid-template-columns: 2fr 1fr; gap:25px; flex-wrap:wrap; margin-bottom:25px;">
            <!-- Attendance Analytics Chart -->
            <div class="card">
                <div class="card-title">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                    </svg>
                    Class Attendance Overview
                </div>

                @if (stats.ClassStats.Any())
                {
                    <div style="display:flex; flex-direction:column; gap:15px; margin-top:10px;">
                        @foreach (var c in stats.ClassStats)
                        {
                            <div>
                                <div style="display:flex; justify-content:space-between; font-size:13px; font-weight:700; margin-bottom:5px;">
                                    <span>@c.ClassName (@c.StudentCount students)</span>
                                    <span>@c.AttendanceRate% Attendance</span>
                                </div>
                                <div style="height:12px; background:var(--gray-100); border-radius:6px; overflow:hidden;">
                                    <div style="width: @(c.AttendanceRate)%; height:100%; background:linear-gradient(90deg, #1A56DB, #7C3AED); border-radius:6px;"></div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p style="color:var(--gray-400); text-align:center; padding:20px;">No student records found to generate attendance reports.</p>
                }
            </div>

            <!-- Upcoming School Events -->
            <div class="card">
                <div class="card-title">Upcoming Events</div>
                @if (upcomingEvents != null && upcomingEvents.Any())
                {
                    <div style="display:flex; flex-direction:column; gap:12px;">
                        @foreach (var ev in upcomingEvents)
                        {
                            <div style="border-left:3px solid @(ev.Type == "Holiday" ? "var(--red)" : ev.Type == "Exam" ? "var(--amber)" : "var(--primary)"); padding-left:10px;">
                                <div style="font-size:13px; font-weight:700; color:var(--gray-800);">@ev.Title</div>
                                <div style="font-size:11px; color:var(--gray-400);">@ev.StartDate.ToString("dd MMM") - @ev.EndDate.ToString("dd MMM yyyy")</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p style="color:var(--gray-400); text-align:center; padding:15px; font-size:13px;">No upcoming events scheduled.</p>
                }
            </div>
        </div>

        <!-- Recent Announcements -->
        <div class="card">
            <div class="card-title">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
                </svg>
                Recent Announcements
            </div>

            @if (recentAnnouncements != null && recentAnnouncements.Any())
            {
                <div style="display:flex; flex-direction:column; gap:15px; margin-top:10px;">
                    @foreach (var ann in recentAnnouncements)
                    {
                        <div style="padding-bottom:12px; border-bottom:1px solid var(--gray-100);">
                            <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:5px; margin-bottom:5px;">
                                <strong style="font-size:14px; color:var(--gray-800);">@ann.Title</strong>
                                <span style="font-size:11px; color:var(--gray-400);">@ann.CreatedAt.ToString("g")</span>
                            </div>
                            <p style="font-size:13px; color:var(--gray-600); margin:0; line-height:1.5;">@ann.Content</p>
                        </div>
                    }
                </div>
            }
            else
            {
                <p style="color:var(--gray-400); text-align:center; padding:15px;">No announcements posted yet.</p>
            }
        </div>

        <!-- View-Powered Reports Section -->
        <div style="display:grid; grid-template-columns: 1fr 1fr; gap:25px; margin-top:25px;">
            <!-- Assignment Progress View -->
            <div class="card">
                <div class="card-title">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                    Assignment Progress
                </div>
                <div style="overflow-x:auto; margin-top:10px;">
                    <table style="width:100%; border-collapse:collapse; font-size:13px; text-align:left;">
                        <thead>
                            <tr style="border-bottom:2px solid var(--gray-200); font-weight:700; color:var(--gray-600);">
                                <th style="padding:10px 5px;">Title</th>
                                <th style="padding:10px 5px;">Class</th>
                                <th style="padding:10px 5px;">Teacher</th>
                                <th style="padding:10px 5px; text-align:center;">Submissions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.AssignmentProgress != null)
                            {
                                foreach (var ap in (List<EduManage.Models.AssignmentProgress>)ViewBag.AssignmentProgress)
                                {
                                    <tr style="border-bottom:1px solid var(--gray-100);">
                                        <td style="padding:10px 5px; font-weight:600; color:var(--gray-800);">@ap.AssignmentTitle</td>
                                        <td style="padding:10px 5px; color:var(--gray-600);">@ap.TargetClass</td>
                                        <td style="padding:10px 5px; color:var(--gray-600);">@ap.TeacherName</td>
                                        <td style="padding:10px 5px; text-align:center;">
                                            <span style="background:var(--primary-light); color:var(--primary); padding:3px 8px; border-radius:12px; font-size:11px; font-weight:700;">
                                                @ap.GradedSubmissions / @ap.TotalSubmissions Graded
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Student Dashboard/Performance View -->
            <div class="card">
                <div class="card-title">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    Student Performance Summary
                </div>
                <div style="overflow-x:auto; margin-top:10px;">
                    <table style="width:100%; border-collapse:collapse; font-size:13px; text-align:left;">
                        <thead>
                            <tr style="border-bottom:2px solid var(--gray-200); font-weight:700; color:var(--gray-600);">
                                <th style="padding:10px 5px;">Name</th>
                                <th style="padding:10px 5px;">Class</th>
                                <th style="padding:10px 5px; text-align:center;">Attendance</th>
                                <th style="padding:10px 5px; text-align:center;">Avg Grade</th>
                                <th style="padding:10px 5px; text-align:center;">Submits</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.StudentOverviews != null)
                            {
                                foreach (var so in (List<EduManage.Models.StudentDashboardOverview>)ViewBag.StudentOverviews)
                                {
                                    <tr style="border-bottom:1px solid var(--gray-100);">
                                        <td style="padding:10px 5px; font-weight:600; color:var(--gray-800);">@so.StudentName</td>
                                        <td style="padding:10px 5px; color:var(--gray-600);">@so.StudentClass (@so.StudentSection)</td>
                                        <td style="padding:10px 5px; text-align:center; font-weight:700; color:@(so.CumulativeAttendancePct >= 90 ? "var(--green)" : "var(--amber)");">
                                            @so.CumulativeAttendancePct%
                                        </td>
                                        <td style="padding:10px 5px; text-align:center; font-weight:700; color:var(--primary);">
                                            @(so.AverageExamScorePct.HasValue ? $"{Math.Round(so.AverageExamScorePct.Value, 1)}%" : "N/A")
                                        </td>
                                        <td style="padding:10px 5px; text-align:center; color:var(--gray-600);">@so.TotalAssignmentsSubmitted</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>
</div>
