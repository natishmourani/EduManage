@model EduManage.Models.Teacher
@{
    ViewData["Title"] = "Change Teacher Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="dashboard">
    @await Html.PartialAsync("_AdminSidebar")

    <main class="main-content">
        <div class="page-header">
            <div class="page-title">Change teacher details</div>
            <div class="page-sub">Update teacher information.</div>
        </div>

        <!-- Search Teacher -->
        <div class="card" style="margin-bottom:16px;">
            <div class="card-title">Search Teacher</div>
            <form asp-action="ChangeTeacher" asp-controller="Admin" method="get">
                <div style="display:flex;gap:10px;">
                    <input class="field-input"
                           name="username"
                           placeholder="Enter teacher username..."
                           value="@ViewBag.Username"
                           style="flex:1;" />
                    <button type="submit" class="btn btn-primary">Search</button>
                </div>
            </form>
        </div>

        @if (Model != null)
        {
            <div class="card">
                <div class="card-title">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor" stroke-width="2">
                        <path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                    Edit teacher — @Model.FullName
                </div>

                <form asp-action="UpdateTeacher" asp-controller="Admin" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="Id" />

                    <div class="form-row">
                        <div>
                            <label class="field-label">Full name *</label>
                            <input asp-for="FullName" class="field-input" required />
                        </div>

                        <div>
                            <label class="field-label">Subject *</label>
                            <select asp-for="Subject" class="field-select" required>
                                <option value="">Select subject</option>
                                @if (ViewBag.Subjects != null)
                                {
                                    foreach (var sub in (List<EduManage.Models.Subject>)ViewBag.Subjects)
                                    {
                                        var isSelected = Model.Subject == sub.Name;
                                        <!option value="@sub.Name" @(isSelected ? "selected" : "")>@sub.Name</!option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div>
                            <label class="field-label">Assigned class *</label>
                            <select asp-for="AssignedClass" class="field-select" required>
                                <option value="">Select class</option>
                                @for (int i = 1; i <= 12; i++)
                                {
                                    var className = $"Class {i}";
                                    <option value="@className" selected="@(Model.AssignedClass == className)">@className</option>
                                }
                            </select>
                        </div>

                        <div>
                            <label class="field-label">Assigned section *</label>
                            <select asp-for="AssignedSection" class="field-select" required>
                                <option value="">Select section</option>
                                @foreach (var sectionOption in new[] { "A", "B", "C", "D" })
                                {
                                    <option value="@sectionOption" selected="@(Model.AssignedSection == sectionOption)">@sectionOption</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div>
                            <label class="field-label">Contact number</label>
                            <input asp-for="Contact" class="field-input" />
                        </div>
                        <div></div>
                    </div>

                    <div class="form-row">
                        <div>
                            <label class="field-label">Username *</label>
                            <input asp-for="Username" class="field-input" required />
                        </div>

                        <div>
                            <label class="field-label">Password *</label>
                            <input asp-for="Password" class="field-input" required />
                        </div>
                    </div>

                    @if (ViewBag.Success != null)
                    {
                        <p style="color: var(--green); font-size:13px; margin-bottom:10px;">
                            @ViewBag.Success
                        </p>
                    }

                    <div class="form-actions">
                        <button type="reset" class="btn btn-outline">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save changes</button>
                    </div>
                </form>
            </div>
        }
        else if (ViewBag.NotFound == true)
        {
            <div class="card"
                 style="text-align:center;padding:40px;color:var(--gray-400);">
                Teacher not found. Please check the username.
            </div>
        }
    </main>
</div>