@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    var adminName = HttpContextAccessor.HttpContext?.Session.GetString("AdminName") ?? "Super Admin";
    var adminRole = HttpContextAccessor.HttpContext?.Session.GetString("AdminRole") ?? "Full access";
    var avatar = !string.IsNullOrEmpty(adminName) && adminName.Length >= 2 ? adminName.Substring(0, 2).ToUpper() : "AD";
}
<!-- Admin Sidebar -->
<aside class="sidebar sidebar-blue">
    <div class="sidebar-brand">
        <div class="brand-icon">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2">
                <path d="M12 14l9-5-9-5-9 5 9 5z"/>
            </svg>
        </div>
        <div>
            <div class="brand-text">EduManage</div>
            <div class="brand-role">Admin portal</div>
        </div>
    </div>

    <div class="sidebar-user">
        <div class="user-avatar">@avatar</div>
        <div>
            <div class="user-name">@adminName</div>
            <div class="user-role">@adminRole</div>
        </div>
    </div>

    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
       asp-action="Index" asp-controller="Admin">
        <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
        Dashboard
    </a>

    <div class="nav-section-label">Students</div>
    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "AddStudent" ? "active" : "")"
       asp-action="AddStudent" asp-controller="Admin">
        <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
        </svg>
        Add students
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "DeleteStudent" ? "active" : "")"
       asp-action="DeleteStudent" asp-controller="Admin">
        <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
        Delete students
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "ChangeDetails" ? "active" : "")"
       asp-action="ChangeDetails" asp-controller="Admin">
        <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        Change details
    </a>

    <div class="nav-section-label">Teachers</div>
    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "AddTeacher" ? "active" : "")"
       asp-action="AddTeacher" asp-controller="Admin">
        <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
        </svg>
        Add teachers
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "DeleteTeacher" ? "active" : "")"
       asp-action="DeleteTeacher" asp-controller="Admin">
        <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
        Delete teachers
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "ChangeTeacher" ? "active" : "")"
       asp-action="ChangeTeacher" asp-controller="Admin">
        <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
        </svg>
        Change details
    </a>

    <div class="nav-section-label">School Portal</div>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Attendance" ? "active" : "")"
       asp-action="Reports" asp-controller="Attendance">
        <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
        </svg>
        Attendance Reports
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Assignment" ? "active" : "")"
       asp-action="Index" asp-controller="Assignment">
        <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        Assignments
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "StudyMaterial" ? "active" : "")"
       asp-action="Index" asp-controller="StudyMaterial">
        <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.168.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.168.477-4.5 1.253"/>
        </svg>
        Study Materials
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Announcement" ? "active" : "")"
       asp-action="Index" asp-controller="Announcement">
        <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
        </svg>
        Announcements
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Exam" ? "active" : "")"
       asp-action="Index" asp-controller="Exam">
        <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
        </svg>
        Exams & Results
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Leave" ? "active" : "")"
       asp-action="Index" asp-controller="Leave">
        <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        Leave Requests
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Message" ? "active" : "")"
       asp-action="Monitor" asp-controller="Message">
        <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
        </svg>
        Monitor Messages
    </a>
    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Event" ? "active" : "")"
       asp-action="Index" asp-controller="Event">
        <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        Event Calendar
    </a>

    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "ChangePassword" ? "active" : "")"
       asp-action="ChangePassword" asp-controller="Admin">
        <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
        Change Password
    </a>

    <div class="sidebar-logout">
        <a class="nav-link" asp-action="Logout" asp-controller="Home">
            <svg width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
            </svg>
            Logout
        </a>
    </div>
</aside>
