@model IEnumerable<EduManage.Models.Announcement>
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Announcements Board";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var role = Context.Session.GetString("Role");
}

<div class="dashboard">
    @if (role == "Admin") { @await Html.PartialAsync("_AdminSidebar") }
    else if (role == "Teacher") { @await Html.PartialAsync("_TeacherSidebar") }
    else if (role == "Student") { @await Html.PartialAsync("_StudentSidebar") }

    <main class="main-content">
        <div class="page-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:15px;">
            <div>
                <div class="page-title">Announcements Board</div>
                <div class="page-sub">Stay updated with the latest news, events, and notices.</div>
            </div>
            @if (role == "Admin" || role == "Teacher")
            {
                <div>
                    <a href="/Announcement/Create" class="btn btn-primary">+ Post Announcement</a>
                </div>
            }
        </div>

        @if (Model != null && Model.Any())
        {
            <div style="display:flex; flex-direction:column; gap:20px;">
                @foreach (var announcement in Model)
                {
                    <div class="card">
                        <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px;">
                            <div>
                                <h3 style="margin:0 0 5px 0; color:var(--gray-800);">@announcement.Title</h3>
                                <div style="font-size:12px; color:var(--gray-400);">
                                    Posted by <strong>@announcement.AuthorName</strong> (@announcement.AuthorRole) &nbsp;·&nbsp; @announcement.CreatedAt.ToString("f")
                                    @if (announcement.ExpiryDate.HasValue)
                                    {
                                        <span> &nbsp;·&nbsp; Visible until @announcement.ExpiryDate.Value.ToString("dd MMM yyyy")</span>
                                    }
                                </div>
                            </div>
                            <div style="display:flex; align-items:center; gap:8px;">
                                <span class="badge @(announcement.TargetClass == "All" ? "badge-blue" : "badge-purple")">
                                    Target: @announcement.TargetClass
                                </span>
                                
                                @if (role == "Admin" || (role == "Teacher" && announcement.AuthorRole == "Teacher" && announcement.AuthorName == Context.Session.GetString("TeacherName")))
                                {
                                    <form method="post" action="/Announcement/Delete" onsubmit="return confirm('Delete this announcement?');" style="margin:0;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@announcement.Id" />
                                        <button type="submit" class="btn btn-danger" style="padding:4px 8px; font-size:11px; margin-bottom:0;">Delete</button>
                                    </form>
                                }
                            </div>
                        </div>
                        <div style="font-size:14px; line-height:1.6; color:var(--gray-700); white-space:pre-wrap; border-top:1px solid var(--gray-100); padding-top:12px;">@announcement.Content</div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="card" style="text-align:center; padding:40px; color:var(--gray-400);">
                <svg width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" style="display:block; margin:0 auto 12px; opacity:.4;">
                    <path d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
                </svg>
                No announcements posted yet.
            </div>
        }
    </main>
</div>
