@model EduManage.Models.Announcement
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Post Announcement";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var role = Context.Session.GetString("Role");
    var classes = (List<string>)ViewBag.Classes;
}

<div class="dashboard">
    @if (role == "Admin") { @await Html.PartialAsync("_AdminSidebar") }
    else if (role == "Teacher") { @await Html.PartialAsync("_TeacherSidebar") }

    <main class="main-content">
        <div class="page-header">
            <div class="page-title">Post Announcement</div>
            <div class="page-sub">Post school-wide updates or message targeted classes.</div>
        </div>

        <div class="card">
            <div class="card-title">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
                </svg>
                Announcement Details
            </div>

            <form method="post" action="/Announcement/Create">
                @Html.AntiForgeryToken()

                <div class="form-row">
                    <div>
                        <label class="field-label">Announcement Title *</label>
                        <input class="field-input" type="text" name="Title" placeholder="e.g. Winter Vacation Notice" required />
                    </div>
                    <div>
                        <label class="field-label">Target Audience *</label>
                        <select class="field-select" name="TargetClass" required>
                            @if (role == "Admin")
                            {
                                <option value="All">All School</option>
                                @foreach (var c in classes)
                                {
                                    <option value="@c">@c</option>
                                }
                            }
                            else
                            {
                                <option value="">Select Class</option>
                                @foreach (var c in classes)
                                {
                                    <option value="@c">@c</option>
                                }
                                <option value="All">All School</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div>
                        <label class="field-label">Visible Until *</label>
                        <input class="field-input" type="date" name="ExpiryDate" required min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        <div style="font-size:11px; color:var(--gray-400); margin-top:4px;">Announcement will be hidden after this date.</div>
                    </div>
                    <div></div>
                </div>

                <div class="form-row full">
                    <div>
                        <label class="field-label">Content *</label>
                        <textarea class="field-input" name="Content" placeholder="Write the announcement body here..." rows="8" required style="height:auto; font-family:inherit; padding:10px;"></textarea>
                    </div>
                </div>

                <div class="form-actions">
                    <a href="/Announcement/Index" class="btn btn-outline">Cancel</a>
                    <button type="submit" class="btn btn-primary">Post Announcement</button>
                </div>
            </form>
        </div>
    </main>
</div>
