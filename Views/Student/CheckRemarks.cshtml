@model IEnumerable<EduManage.Models.Remark>
@{
    ViewData["Title"] = "Check Remarks";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="dashboard">
    @await Html.PartialAsync("_StudentSidebar")

    <main class="main-content">
        <div class="page-header">
            <div class="page-title">Check remarks</div>
            <div class="page-sub">Teacher ne jo remarks likhe hain</div>
        </div>

        <div class="card">
            <div class="card-title">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
                My remarks
            </div>

            @if (Model != null && Model.Any())
            {
                @foreach (var r in Model)
                {
                    <div style="border:1px solid var(--gray-200);border-radius:10px;padding:14px 16px;margin-bottom:10px;">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                            <span class="badge @(r.RemarkType == "Academic" ? "badge-blue" : r.RemarkType == "Behavior" ? "badge-amber" : "badge-gray")">
                                @r.RemarkType
                            </span>
                            <span style="font-size:12px;color:var(--gray-400);">
                                @r.CreatedAt.ToString("d MMM yyyy")
                            </span>
                        </div>
                        <p style="font-size:14px;margin:0;color:var(--gray-700);">@r.RemarkText</p>
                        <div style="margin-top:8px;font-size:12px;color:var(--gray-400);">
                            — @r.TeacherName
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="text-align:center;padding:40px;color:var(--gray-400);">
                    <svg width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" style="display:block;margin:0 auto 12px;opacity:.4;">
                        <path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                    </svg>
                    Abhi tak koi remark nahi hai
                </div>
            }
        </div>
    </main>
</div>
