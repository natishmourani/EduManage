@model IEnumerable<EduManage.Controllers.ClassAttendanceStat>
@{
    ViewData["Title"] = "Attendance Reports";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="dashboard">
    @await Html.PartialAsync("_AdminSidebar")

    <main class="main-content">
        <div class="page-header">
            <div class="page-title">Attendance Reports & Statistics</div>
            <div class="page-sub">Monitor student attendance rates across all classes.</div>
        </div>

        <div class="card">
            <div class="card-title">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
                Class-wise Attendance Stats
            </div>

            @if (Model != null && Model.Any())
            {
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Class Name</th>
                            <th>Total Students</th>
                            <th>Average Attendance Rate</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var stat in Model)
                        {
                            var pct = stat.AverageAttendance;
                            <tr>
                                <td><strong>@stat.ClassName</strong></td>
                                <td>@stat.StudentCount students</td>
                                <td>
                                    <div style="display:flex; align-items:center; gap:10px;">
                                        <span class="badge @(pct >= 85 ? "badge-green" : pct >= 75 ? "badge-blue" : pct >= 60 ? "badge-amber" : "badge-danger")">
                                            @pct%
                                        </span>
                                        <div style="flex:1; max-width:150px; height:8px; background:var(--gray-100); border-radius:4px; overflow:hidden;">
                                            <div style="width:@pct%; height:100%; background:@(pct >= 85 ? "var(--green)" : pct >= 75 ? "var(--primary)" : pct >= 60 ? "var(--amber)" : "var(--red)");"></div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <a href="/Attendance/History?className=@stat.ClassName" class="btn btn-outline" style="font-size:12px; padding:6px 12px;">View Daily Logs</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div style="color:var(--gray-400); padding:30px; text-align:center;">No class attendance statistics found yet.</div>
            }
        </div>
    </main>
</div>
