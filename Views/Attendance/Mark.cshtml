@model IEnumerable<EduManage.Models.Student>
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Mark Attendance";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var role = Context.Session.GetString("Role");
    var selectedDate = (DateTime)ViewBag.SelectedDate;
    var className = (string)ViewBag.ClassName;
    var classes = (List<string>)ViewBag.Classes;
    var records = (Dictionary<int, EduManage.Models.Attendance>)ViewBag.AttendanceRecords;
}

<div class="dashboard">
    @if (role == "Admin") { @await Html.PartialAsync("_AdminSidebar") }
    else if (role == "Teacher") { @await Html.PartialAsync("_TeacherSidebar") }

    <main class="main-content">
        <div class="page-header">
            <div class="page-title">Mark Attendance</div>
            <div class="page-sub">Select class and date to mark or update student attendance.</div>
        </div>

        <div class="card">
            <div class="card-title">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
                </svg>
                Filter Options
            </div>

            <form method="get" action="/Attendance/Mark" style="display:flex; gap:15px; align-items:flex-end; flex-wrap:wrap; margin-bottom:15px;">
                <div style="flex:1; min-width:200px;">
                    <label class="field-label">Class</label>
                    @if (role == "Teacher")
                    {
                        <select class="field-select" disabled>
                            <option value="@className">@className</option>
                        </select>
                        <input type="hidden" name="className" value="@className" />
                    }
                    else
                    {
                        <select class="field-select" name="className" required>
                            <option value="">Select Class</option>
                            @foreach (var c in classes)
                            {
                                <!option value="@c" @(c == className ? "selected" : "")>@c</!option>
                            }
                        </select>
                    }
                </div>
                <div style="flex:1; min-width:200px;">
                    <label class="field-label">Subject</label>
                    @if (role == "Teacher")
                    {
                        <select class="field-select" disabled>
                            <option value="@ViewBag.Subject">@ViewBag.Subject</option>
                        </select>
                        <input type="hidden" name="subject" value="@ViewBag.Subject" />
                    }
                    else
                    {
                        var subjects = (List<string>)ViewBag.Subjects ?? new List<string>();
                        <select class="field-select" name="subject" required>
                            <option value="">Select Subject</option>
                            @foreach (var s in subjects)
                            {
                                <!option value="@s" @(s == ViewBag.Subject ? "selected" : "")>@s</!option>
                            }
                        </select>
                    }
                </div>
                <div style="flex:1; min-width:200px;">
                    <label class="field-label">Date</label>
                    <input class="field-input" type="date" name="date" value="@selectedDate.ToString("yyyy-MM-dd")" required max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
                <div>
                    <button type="submit" class="btn btn-primary" style="margin-bottom:0;">Load Students</button>
                </div>
            </form>
        </div>

        @if (!string.IsNullOrEmpty(className))
        {
            <div class="card" style="margin-top:20px;">
                <div class="card-title">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                    </svg>
                    Student List for @className (@selectedDate.ToString("dd MMMM yyyy"))
                </div>

                @if (Model != null && Model.Any())
                {
                    <form method="post" action="/Attendance/Save">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="className" value="@className" />
                        <input type="hidden" name="subject" value="@ViewBag.Subject" />
                        <input type="hidden" name="date" value="@selectedDate.ToString("yyyy-MM-dd")" />

                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Roll No</th>
                                    <th>Student Name</th>
                                    <th>Status</th>
                                    <th>Remarks</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model)
                                {
                                    var currentStatus = records.ContainsKey(s.Id) ? records[s.Id].Status : "Present";
                                    var currentRemarks = records.ContainsKey(s.Id) ? records[s.Id].Remarks : "";
                                    <tr>
                                        <td>@s.RollNumber</td>
                                        <td>@s.FullName</td>
                                        <td>
                                            <div style="display:flex; gap:12px; align-items:center;">
                                                <label style="cursor:pointer; display:flex; align-items:center; gap:4px; font-size:13px;">
                                                    <input type="radio" name="statuses[@s.Id]" value="Present" @(currentStatus == "Present" ? "checked" : "") /> Present
                                                </label>
                                                <label style="cursor:pointer; display:flex; align-items:center; gap:4px; font-size:13px;">
                                                    <input type="radio" name="statuses[@s.Id]" value="Absent" @(currentStatus == "Absent" ? "checked" : "") /> Absent
                                                </label>
                                                <label style="cursor:pointer; display:flex; align-items:center; gap:4px; font-size:13px;">
                                                    <input type="radio" name="statuses[@s.Id]" value="Leave" @(currentStatus == "Leave" ? "checked" : "") /> Leave
                                                </label>
                                            </div>
                                        </td>
                                        <td>
                                            <input class="field-input" type="text" name="remarks[@s.Id]" value="@currentRemarks" placeholder="Optional remark" style="padding:6px 10px; font-size:12px; margin-bottom:0;" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <div class="form-actions" style="margin-top:20px;">
                            <button type="submit" class="btn btn-primary">Save Attendance</button>
                        </div>
                    </form>
                }
                else
                {
                    <div style="color:var(--gray-400); padding:20px; text-align:center;">No students found in this class.</div>
                }
            </div>
        }
    </main>
</div>
