@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Attendance History";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var role = Context.Session.GetString("Role");
    var className = (string)ViewBag.ClassName;
    var classes = (List<string>)ViewBag.Classes;
    var historyData = (List<dynamic>)ViewBag.HistoryData;
}

<div class="dashboard">
    @if (role == "Admin") { @await Html.PartialAsync("_AdminSidebar") }
    else if (role == "Teacher") { @await Html.PartialAsync("_TeacherSidebar") }

    <main class="main-content">
        <div class="page-header">
            <div class="page-title">Attendance History</div>
            <div class="page-sub">View daily attendance summaries for class students.</div>
        </div>

        <div class="card">
            <div class="card-title">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
                </svg>
                Select Class
            </div>

            <form method="get" action="/Attendance/History" style="display:flex; gap:15px; align-items:flex-end; flex-wrap:wrap; margin-bottom:15px;">
                <div style="flex:1; min-width:200px;">
                    <label class="field-label">Class</label>
                    @if (role == "Teacher")
                    {
                        <select class="field-select" disabled>
                            <option value="@className">@className</option>
                        </select>
                        <input type="hidden" name="className" value="@className" />
                    }
                    else
                    {
                        <select class="field-select" name="className" required>
                            <option value="">Select Class</option>
                            @foreach (var c in classes)
                            {
                                <!option value="@c" @(c == className ? "selected" : "")>@c</!option>
                            }
                        </select>
                    }
                </div>
                <div>
                    <button type="submit" class="btn btn-primary" style="margin-bottom:0;">Load History</button>
                </div>
            </form>
        </div>

        @if (!string.IsNullOrEmpty(className))
        {
            <div class="card" style="margin-top:20px;">
                <div class="card-title">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    Daily History for @className
                </div>

                @if (historyData != null && historyData.Any())
                {
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Total Students</th>
                                <th>Present</th>
                                <th>Absent</th>
                                <th>On Leave</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var record in historyData)
                            {
                                <tr>
                                    <td>@record.Date.ToString("dd MMMM yyyy")</td>
                                    <td>@record.Total</td>
                                    <td><span class="badge badge-green">@record.Present Present</span></td>
                                    <td><span class="badge badge-danger">@record.Absent Absent</span></td>
                                    <td><span class="badge badge-amber">@record.Leave Leave</span></td>
                                    <td>
                                        <a href="/Attendance/Mark?className=@className&date=@record.Date.ToString("yyyy-MM-dd")" class="btn btn-outline" style="font-size:12px; padding:6px 12px;">Edit</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div style="color:var(--gray-400); padding:20px; text-align:center;">No attendance history found for this class.</div>
                }
            </div>
        }
    </main>
</div>
